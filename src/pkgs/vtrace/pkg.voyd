use self::hit::HittableList
use self::vec3::all
use self::sphere::Sphere
use self::camera::Camera

pub fn draw()
  // Image
  let aspect_ratio = 16.0 / 9.0
  let image_width = 400

  let world = HittableList()
    .added(Sphere(Point3(0.0, 0.0, -1.0), 0.5))
    .added(Sphere(Point3(0.0, -100.5, -1.0), 100.0))

  Camera({ aspect_ratio, image_width })
    .render(world)
